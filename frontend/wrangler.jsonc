{
  "name": "ocr-frontend",
  "account_id": "6cf5b7ff46b291e95096647771d0ddc9",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "scheung.dev/*",
      "script": "ocr-frontend"
    }
  ],
  "build": {
    "command": "npm run build",
    "cwd": "./"
  },
  "env": {
    "production": {
      "workers_dev": false,
      "routes": [
        {
          "pattern": "scheung.dev/*"
        }
      ]
    }
  }
}